{
  "name": "cloudflare-linker",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.node.json && tsc -p tsconfig.test.json",
    "test": "bun test",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply cloudflare-linker-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply cloudflare-linker-db --remote",
    "db:seed": "wrangler d1 execute cloudflare-linker-db --local --file=./src/db/seed.sql",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.3",
    "@types/bun": "latest",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "0.31.10",
    "typescript": "5.9.3",
    "vite": "8.1.0",
    "wrangler": "4.105.0"
  },
  "dependencies": {
    "@orpc/client": "1.14.6",
    "@orpc/contract": "1.14.6",
    "@orpc/react-query": "1.14.6",
    "@orpc/server": "1.14.6",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@tanstack/react-query": "^5.101.1",
    "drizzle-orm": "0.45.2",
    "jose": "6.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-is": "19.2.7",
    "recharts": "3.9.0",
    "wouter": "3.10.0",
    "zod": "^4.4.3"
  }
}
