{
  // React SPA (browser). DOM libs + Vite client types only.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  },
  "include": ["src/client", "src/shared"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
